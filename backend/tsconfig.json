  "compilerOptions": {
    "target": "es2015",
    "ignoreDeprecations": "6.0",
    "strict": false,
    "esModuleInterop": true,
    "outDir": "./modules",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}